# PostgreSQL remains private inside the Docker network.
POSTGRES_DB=environment
POSTGRES_USER=environment
POSTGRES_PASSWORD=CHANGE_TO_A_LONG_RANDOM_PASSWORD
DATABASE_READ_ENABLED=true
DATABASE_WRITE_ENABLED=true
DATABASE_REQUIRED=false
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_BATCH_SIZE=2000

MONITORING_DATA_PATH=data/processed/air_quality_clean.csv
LIVE_AIR_DATA_PATH=data/raw/air_quality.csv
LIVE_WEATHER_DATA_PATH=data/raw/weather.csv
LIVE_TRAFFIC_DATA_PATH=data/raw/traffic.csv
TRAFFIC_MAX_AGE_MINUTES=120
FEATURE_DATA_PATH=data/processed/ml_features.csv.gz
ALERT_STORE_PATH=artifacts/alerts/alerts.json
NEWS_CACHE_PATH=artifacts/news/news_cache.json
NEWS_CACHE_TTL_SECONDS=1800
NEWS_TIMEOUT_SECONDS=20

# Keep exactly one API replica while the embedded hourly scheduler is enabled.
HOURLY_UPDATES_ENABLED=true
HOURLY_UPDATE_RUN_ON_STARTUP=true
HOURLY_UPDATE_TIMEZONE=Asia/Ho_Chi_Minh
HOURLY_UPDATE_DELAY_SECONDS=45
HOURLY_UPDATE_RETRY_MINUTES=5
HOURLY_UPDATE_CONFIG_PATH=config.yaml
HOURLY_UPDATE_STATUS_PATH=artifacts/hourly_update_status.json

TOMTOM_API_KEY=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_SECONDS=60
GROQ_MAX_OUTPUT_TOKENS=1400
GROQ_TEMPERATURE=0.1

PDF_FONT_REGULAR=
PDF_FONT_BOLD=
